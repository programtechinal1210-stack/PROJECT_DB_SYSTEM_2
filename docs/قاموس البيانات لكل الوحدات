email_verified_at TIMESTAMP  تاريخ التحقق من البريد nullable
last_login TIMESTAMP  آخر تسجيل دخول nullable
last_login_ip INET  آخر IP تم الدخول منه nullable
login_attempts INT  عدد المحاولات الفاشلة default: 0
locked_until TIMESTAMP  مدة قفل الحساب nullable
employee_id INT FK → hr.employees الموظف المرتبط nullable
preferences JSONB  تفضيلات المستخدم default: {}
metadata JSONB  بيانات إضافية default: {}
created_at TIMESTAMP  تاريخ الإنشاء default: CURRENT_TIMESTAMP
updated_at TIMESTAMP  آخر تحديث default: CURRENT_TIMESTAMP
