 
# =============================================
# FILE: docker/docker-compose.yml
# PURPOSE: تشغيل بيئة قاعدة البيانات الكاملة مع health checks
# =============================================

version: '3.8'

services:
 postgres:
  image: postgres:15-alpine
  container_name: project_db
  environment:
    POSTGRES_DB: project_db_system
    POSTGRES_USER: project_user
    POSTGRES_PASSWORD: ${DB_PASSWORD:-Project@123456}
    POSTGRES_INITDB_ARGS: "--encoding=UTF8"
    TZ: 'Asia/Riyadh'
  ports:
    - "5432:5432"
  volumes:
    - postgres_data:/var/lib/postgresql/data
    - ../../database/bootstrap:/docker-entrypoint-initdb.d
    - ../../database/backups:/backups
    - ./postgresql.conf:/etc/postgresql/postgresql.conf:ro
    - ./pg_hba.conf:/etc/postgresql/pg_hba.conf:ro
    - ./healthcheck.sql:/healthcheck.sql:ro
  healthcheck:
    test: ["CMD-SHELL", "pg_isready -U project_user -d project_db_system"]
    interval: 30s
    timeout: 10s
    retries: 5
    start_period: 40s
  networks:
    - project_network
  restart: unless-stopped
  deploy:
    resources:
      limits:
        cpus: '2'
        memory: 2G
      reservations:
        memory: 1G
  logging:
    driver: "json-file"
    options:
      max-size: "10m"
      max-file: "3"

  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: project_pgadmin
    environment:
      PGADMIN_DEFAULT_EMAIL: ${PGADMIN_EMAIL:-admin@project.com}
      PGADMIN_DEFAULT_PASSWORD: ${PGADMIN_PASSWORD:-Admin@123}
      PGADMIN_CONFIG_SERVER_MODE: 'False'
      PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED: 'False'
      PGADMIN_CONFIG_ENHANCED_COOKIE_PROTECTION: 'False'
    ports:
      - "5050:80"
    volumes:
      - pgadmin_data:/var/lib/pgadmin
      - ./servers.json:/pgadmin4/servers.json:ro
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - project_network
    restart: unless-stopped
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  redis:
    image: redis:7-alpine
    container_name: project_redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
      - ./redis.conf:/usr/local/etc/redis/redis.conf:ro
    command: redis-server /usr/local/etc/redis/redis.conf
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - project_network
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 512M
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

volumes:
  postgres_data:
    driver: local
    name: project_postgres_data
  pgadmin_data:
    driver: local
    name: project_pgadmin_data
  redis_data:
    driver: local
    name: project_redis_data

networks:
  project_network:
    driver: bridge
    name: project_network